{
  "name": "joby-r2-videos-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker para upload de vídeos no R2",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npx wrangler dev --local --ip 127.0.0.1 --port 8787",
    "dev:local": "npx wrangler dev --local --ip 127.0.0.1 --port 8787",
    "dev:remote": "npx wrangler dev --remote --ip 127.0.0.1 --port 8787",
    "deploy": "npx wrangler deploy",
    "tail": "npx wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260109.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.59.1"
  }
}
