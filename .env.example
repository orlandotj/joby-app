# Copy to .env (do NOT commit .env) and fill your keys
#
# Frontend (Vite only exposes vars starting with VITE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Worker API base URL (Cloudflare Worker)
# Example: https://joby-r2-videos.<your-account>.workers.dev
VITE_WORKER_API_URL=

# Back-compat (older name used in the codebase)
VITE_CLOUDFLARE_WORKER_URL=

# Optional feature flags
VITE_ENABLE_SUPABASE_REALTIME=false
