# Exemplo para PRODUÇÃO (não commitar .env.production com secrets)
# Aqui você deve apontar para o Worker PUBLICADO (não localhost)
# Depois do deploy do worker, você terá algo como:
# https://joby-r2-videos.<account>.workers.dev
VITE_CLOUDFLARE_WORKER_URL=https://joby-r2-videos.<account>.workers.dev

# Serviço Node (faststart upload) publicado
VITE_FASTSTART_API_URL=https://joby-upload.<seu-dominio>

# Mantém Supabase (frontend usa anon key)
VITE_SUPABASE_URL=https://zkmgjgostowsllmdrrjd.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
