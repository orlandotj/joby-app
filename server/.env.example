# Server
PORT=8788
# Allowed web origins (comma-separated). Use full origin (scheme + host + port).
# Examples (DEV):
# - Localhost (Vite can move ports if busy):
#   CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# - Loopback:
#   CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
# - LAN (para testar no celular):
#   CORS_ORIGINS=http://SEU_IP:5173,http://SEU_IP:5174,http://SEU_IP:5175
# - PROD (exemplo):
#   CORS_ORIGINS=https://app.joby.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# Legacy single-origin (still supported, but prefer CORS_ORIGINS)
# CORS_ORIGIN=http://localhost:5173

# Upload limit (bytes). 200MB default:
MAX_VIDEO_BYTES=209715200

# R2 (S3-compatible)
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET_NAME=...

# Supabase (service role is required to insert metadata server-side)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Optional: used only to compute playbackUrl in the response
WORKER_BASE_URL=https://<your-worker-or-domain>

# Optional: ffmpeg binary name/path
# FFMPEG_PATH=ffmpeg
